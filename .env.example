# --------------------------------------------------------------------
# OpenUI Demo — pick ONE provider (or set multiple keys; the app will
# default to whichever is configured). All can be overridden at
# runtime via the in-app Settings dialog (saved in localStorage).
# --------------------------------------------------------------------

# Active provider: groq | openrouter | gemini  (optional; auto-detected
# from whichever key is set if you leave this blank).
VITE_LLM_PROVIDER=groq

# Active model (optional; defaults to the provider's recommended model).
# Examples by provider:
#   groq        -> openai/gpt-oss-120b, openai/gpt-oss-20b, llama-3.3-70b-versatile
#   openrouter  -> openai/gpt-4o-mini, anthropic/claude-3.5-sonnet, google/gemini-2.0-flash-001
#   gemini      -> gemini-2.5-flash, gemini-2.5-pro, gemini-2.0-flash
VITE_LLM_MODEL=openai/gpt-oss-120b

# --- Provider keys (only the active provider's key is used) ---
# Get a Groq key at https://console.groq.com/keys
VITE_GROQ_API_KEY=

# Get an OpenRouter key at https://openrouter.ai/keys
VITE_OPENROUTER_API_KEY=

# Get a Gemini key at https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=
